<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <report 
            id="action_reportn_saleorder"
            string="Quotation / Order_n"
            model="sale.order" 
            report_type="qweb-pdf"
            file="maz_stock_management.reportn_saleorder" 
            name="maz_stock_management.reportn_saleorder"
            print_report_name="(object.state in ('draft', 'sent') and 'Quotation - %s' % (object.name)) or 'Order - %s' % (object.name)"
        />

        <report
            id="action_reportn_pro_forma_invoice"
            string="PRO-FORMA Invoice_N"
            model="sale.order"
            report_type="qweb-pdf"
            groups="sale.group_proforma_sales"
            file="maz_stock_management.reportn_saleorder_pro_forma"
            name="maz_stock_management.reportn_saleorder_pro_forma"
            print_report_name="'PRO-FORMA - %s' % (object.name)"
        />
    </data>
</odoo>
