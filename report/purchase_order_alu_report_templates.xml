<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Adds Length (m), Total Length (m) and Total Weight (kg) columns to
        the standard Purchase Order / RFQ PDF report, for aluminum profile
        lines purchased by the piece and priced per kg. Quantity, Unit Price
        and Subtotal are already shown by the core report - see
        PURCHASE_ALUMINUM_WEIGHT_PRICING.md.
    -->
    <template id="report_purchaseorder_document_inherit_alu"
              inherit_id="purchase.report_purchaseorder_document">

        <xpath expr="//th[@name='th_quantity']" position="after">
            <th name="th_alu_length_per_piece" class="text-end">
                <strong>Length (m)</strong>
            </th>
            <th name="th_alu_total_length" class="text-end">
                <strong>Total Length (m)</strong>
            </th>
            <th name="th_alu_total_weight" class="text-end">
                <strong>Total Weight (kg)</strong>
            </th>
        </xpath>

        <xpath expr="//td[@id='product']/following-sibling::td[1]" position="after">
            <td name="td_alu_length_per_piece" class="text-end">
                <span t-if="line.profile_length"
                      t-field="line.profile_length"/>
            </td>
            <td name="td_alu_total_length" class="text-end">
                <span t-if="line.alu_total_length"
                      t-field="line.alu_total_length"/>
            </td>
            <td name="td_alu_total_weight" class="text-end">
                <span t-if="line.alu_total_weight"
                      t-field="line.alu_total_weight"/>
            </td>
        </xpath>

        <!-- The 3 new <td> above must line up with the section/note rows
             too (they use colspan="99" so no change needed there), but the
             section/subtotal <tr> spans every column via colspan already,
             so nothing else needs adjusting. -->
    </template>
</odoo>
