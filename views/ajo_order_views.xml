<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_ajo_order_list" model="ir.ui.view">
        <field name="name">ajo.order.list</field>
        <field name="model">ajo_order</field>
        <field name="arch" type="xml">
            <list string="AJO Orders">
                <field name="company_id" groups="base.group_multi_company"/>                       
                <field name="name"/>
                <field name="project_ref"/>
                <field name="warehouse_id"/>
                <field name="warehouse_code"/>
                <field name="pm_id" widget="many2one_avatar_user"/>
                <field name="date"/>
                <field name="block"/>
            </list>
        </field>
    </record>
    <record id="view_ajo_order_line_search" model="ir.ui.view">
        <field name="name">ajo.order.line.search</field>
        <field name="model">ajo_order_line</field>
        <field name="arch" type="xml">
            <search string="Search Order Lines">
                <filter string="Glass Material" 
                        name="filter_glass_material" 
                        domain="[('material_type', '=', 'glass')]"/>
                <filter string="ALUM Material" 
                        name="filter_alum_material" 
                        domain="[('material_type', '=', 'aluminum')]"/>
            </search>
        </field>
    </record>
    <record id="view_ajo_order_form" model="ir.ui.view">        
        <field name="name">ajo.order.form</field>
        <field name="model">ajo_order</field>
        <field name="arch" type="xml">
            <form string="AJO Order">
                <header>
                    <button name="action_generate_manufacturing"
                            type="object"
                            string="Generate Manufacturing Order"
                            class="oe_highlight"
                            icon="fa-industry"/>
                    <button name="action_mopen_label_layout"
                            type="object"
                            string="Print Barcodes"
                            class="oe_highlight"
                            icon="fa-print"/>
                    <button name="action_popen_label_layout"
                            type="object"
                            string="Print Parent Barcodes"
                            class="oe_highlight"
                            icon="fa-print"/>
                    <span class="oe_title">
                        Qty to Order:    
                    </span>       
                    <button name="action_open_cutlist_sum"
                            type="object"
                            string="Profiles"
                            class="oe_highlight"
                            icon="fa-external-link"/>
                    <button name="action_open_glass_cutlist_sum"
                        type="object"
                        string="Glass"
                        class="oe_highlight"
                        icon="fa-external-link"/>
                    <button name="action_open_acc_cutlist_sum"
                        type="object"
                        string="Accesories"
                        class="oe_highlight"
                        icon="fa-external-link"/>
                    <button name="action_open_acp_cutlist_sum"
                        type="object"
                        string="ACP/SCP"
                        class="oe_highlight"
                        icon="fa-external-link"/>
                    <button name="action_open_steel_cutlist_sum"
                        type="object"
                        string="Steel"
                        class="oe_highlight"
                        icon="fa-external-link"/>    
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="AJO-0001"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Project Information">
                            <field name="project_ref"/>
                            <field name="project_code"/>
                            <field name="pm_id" widget="many2one_avatar_user"/>
                        </group>
                        <group string="Logistics">
                            <field name="warehouse_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="warehouse_code" readonly="1"/>
                            <field name="date"/>
                        </group>
                    </group>
                    <group string="Location Details">
                        <group>
                            <field name="block"/>
                            <field name="handle"/>
                        </group>
                        <group>
                            <field name="floor"/>
                        </group>
                    </group>                    
                    <!-- The Order Lines List Embedded Inside a Tab -->
                    <notebook>
                        <page string="Details" name="order_lines">
                            <div class="oe_title">
                                <h1>
                                    Aluminium Profiles
                                </h1>
                            </div>
                            <field name="alum_order_line_ids" context="{'default_material_type': 'aluminum'}" >
                                <list editable="bottom">
                                    <field name="item_ref"/>
                                    <field name="product_id" domain="[('product_tmpl_id.material_type', '!=', False), ('product_tmpl_id.material_type', '=', 'aluminum')]"/>
                                    <field name="alum_profile"/>
                                    <field name="color"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="qty"/>
                                    <field name="product_uom_id"/>
                                    <field name="angle"/>
                                    <field name="length"/>
                                </list>
                            </field>
                            <div class="oe_title">
                                <h1>
                                    Accessories
                                </h1>
                            </div>
                            <field name="acc_order_line_ids" context="{'default_material_type': 'accessory'}" >
                                <list editable="bottom">
                                    <field name="item_ref"/>
                                    <field name="product_id" domain="[('product_tmpl_id.material_type', '!=', False), ('product_tmpl_id.material_type', '=', 'accessory')]"/>
                                    <field name="alum_profile"/>
                                    <field name="color"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="qty"/>
                                    <field name="product_uom_id"/>
                                    <field name="angle"/>
                                    <field name="material_type"/>
                                    <field name="length"/>
                                </list>
                            </field>
                            <div class="oe_title">
                                <h1>
                                    Glass
                                </h1>
                            </div>
                            <field name="glass_order_line_ids" context="{'default_material_type': 'glass'}" >
                                <list editable="bottom">
                                    <field name="item_ref"/>
                                    <field name="product_id" domain="[('product_tmpl_id.material_type', '!=', False), ('product_tmpl_id.material_type', '=', 'glass')]"/>
                                    <field name="alum_profile"/>
                                    <field name="color"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="qty"/>
                                    <field name="product_uom_id"/>
                                    <field name="angle"/>
                                    <field name="material_type"/>
                                    <field name="length"/>
                                </list>
                            </field>
                            <div class="oe_title">
                                <h1>
                                    ACP/SCP
                                </h1>
                            </div>
                            <field name="acp_order_line_ids" context="{'default_material_type': 'acp'}" >
                                <list editable="bottom">
                                    <field name="item_ref"/>
                                    <field name="product_id" domain="[('product_tmpl_id.material_type', '!=', False), ('product_tmpl_id.material_type', '=', 'acp')]"/>
                                    <field name="alum_profile"/>
                                    <field name="color"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="qty"/>
                                    <field name="product_uom_id"/>
                                    <field name="angle"/>
                                    <field name="material_type"/>
                                    <field name="length"/>
                                </list>
                            </field>
                            <div class="oe_title">
                                <h1>
                                    Steel
                                </h1>
                            </div>
                            <field name="steel_order_line_ids" context="{'default_material_type': 'steel'}" >
                                <list editable="bottom">
                                    <field name="item_ref"/>
                                    <field name="product_id" domain="[('product_tmpl_id.material_type', '!=', False), ('product_tmpl_id.material_type', '=', 'steel')]"/>
                                    <field name="alum_profile"/>
                                    <field name="color"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="qty"/>
                                    <field name="product_uom_id"/>
                                    <field name="angle"/>
                                    <field name="material_type"/>
                                    <field name="length"/>
                                </list>
                            </field>
                        </page>                        
                    </notebook>
                </sheet>
                    <!-- 2. PLACE THE CHATTER PANEL HERE (Outside <sheet>, inside <form>) -->
                    <chatter>
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </chatter>
            </form>
        </field>
    </record>

    <record id="action_ajo_order" model="ir.actions.act_window">
        <field name="name">AJO Orders</field>
        <field name="res_model">ajo_order</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_maz_angle" model="ir.actions.act_window">
        <field name="name">Angles</field>
        <field name="res_model">angle</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_maz_profile" model="ir.actions.act_window">
        <field name="name">Profiles</field>
        <field name="res_model">alum_profile</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_maz_color" model="ir.actions.act_window">
        <field name="name">Colors</field>
        <field name="res_model">product_color</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_maz_sub_category" model="ir.actions.act_window">
        <field name="name">Sub Categories</field>
        <field name="res_model">product_sub_category</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_ajo_glass_type" model="ir.actions.act_window">
        <field name="name">Glass Types</field>
        <field name="res_model">ajo_glass_type</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_ajo_glass_thickness" model="ir.actions.act_window">
        <field name="name">Glass Thicknesses</field>
        <field name="res_model">ajo_glass_thickness</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_ajo"
        name="ALUMEC Prod"
        web_icon="maz_alumec_ajo,static/description/alumec.png"
        sequence="10"/>
    <menuitem
        id="menu_ajo_order"
        name="Aluminium Job Order"
        parent="menu_ajo"
        action="action_ajo_order"
        sequence="12"/>
    <menuitem
        id="ajo_settings"
        name="Settings"
        parent="menu_ajo"
        sequence="20"/>    
    <menuitem
        id="settings_angle"
        name="Angles"
        parent="ajo_settings"
        action="action_maz_angle"
        sequence="10"/>   
    <menuitem
        id="settings_color"
        name="Colors"
        parent="ajo_settings"
        action="action_maz_color"
        sequence="10"/>   
    <menuitem
        id="settings_profile"
        name="Profiles"
        parent="ajo_settings"
        action="action_maz_profile"
        sequence="10"/>
    <menuitem
        id="settings_sub_category"
        name="Sub Categories"
        parent="ajo_settings"
        action="action_maz_sub_category"
        sequence="10"/>
    <menuitem
        id="settings_window_template"
        name="Window Templates"
        parent="ajo_settings"
        action="action_ajo_window_template"
        sequence="10"/>
    <menuitem
        id="settings_glass_type"
        name="Glass Types"
        parent="ajo_settings"
        action="action_ajo_glass_type"
        sequence="10"/>
    <menuitem
        id="settings_glass_thickness"
        name="Glass Thicknesses"
        parent="ajo_settings"
        action="action_ajo_glass_thickness"
        sequence="10"/>

    <menuitem id="products" name="Products" 
              parent="menu_ajo"
              action="stock.product_template_action_product"
              sequence="14"/> 

    <menuitem id="purchase_rfq" name="Purchase RFQ" 
              parent="menu_ajo"
              action="purchase.purchase_rfq"
              sequence="15"/>               

    <menuitem id="purchase_order" name="Purchase order" 
              parent="menu_ajo"
              action="purchase.purchase_form_action"
              sequence="16"/>

    <menuitem id="manufacturing" name="Manufacturing" 
              parent="menu_ajo"
              action="mrp.mrp_production_action"
              sequence="17"/> 
    <menuitem id="iso_checklists" name="ISO Checklists" 
              parent="menu_ajo"
              action="action_purchase_order_line_checklist"
              sequence="18"/>                                                    
</odoo>