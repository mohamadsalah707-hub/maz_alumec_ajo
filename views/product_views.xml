<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Form View Extension -->
    <record id="view_product_template_form_inherit" model="ir.ui.view">
        <field name="name">product.template.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Aluminium Specs" name="alum_specs">
                    <!-- Fixed 'cols' typo to 'col' -->
                    <group col="4">
                        <group string="Primary Info">
                            <field name="material_type"/>
                            <field name="alum_profile"/>
                            <field name="color_id"/>
                            <field name="categ_id"/>
                            <field name="sub_categ_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Dimensions">
                            <field name="length"/>
                            <field name="width"/>
                            <field name="weight"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- List View Extension -->
    <record id="view_product_template_list_inherit" model="ir.ui.view">
        <!-- Kept ID and Name conventions consistent with Odoo core naming layouts -->
        <field name="name">product.template.product.list.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <!-- Targeting the modern root <list> tag structure -->
            <xpath expr="//list" position="inside">
                <!--field name="item_ref" optional="show"/-->
                <field name="alum_profile" optional="show"/>
                <field name="color_id" optional="show"/>
                <field name="length" optional="show"/>
                <field name="width" optional="hide"/>
                <field name="sub_categ_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
