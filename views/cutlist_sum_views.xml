<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_cutlist_sum_list" model="ir.ui.view">
        <field name="name">cutlist.sum.list</field>
        <field name="model">cutlist_sum</field>
        <field name="arch" type="xml">
            <list string="Cut List Summaries">
                <field name="name"/>
                <field name="project_code"/>
                <field name="warehouse_id"/>
                <field name="date"/>
                <field name="totqtytoorder"/>
                <field name="totmaxqtyneeded"/>
            </list>
        </field>
    </record>
    <record id="view_cutlist_sum_form" model="ir.ui.view">
        <field name="name">cutlist.sum.form</field>
        <field name="model">cutlist_sum</field>
        <field name="arch" type="xml">
            <form string="Cut List Summary">
                    <header>
						<button string="Raise RFQ" name="action_new_rfq" type="object" class="oe_highlight" />
					</header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="AJO-0001" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                    <group string="Order Information">
                        <field name="ajo_order_id"/>
                        <field name="project_code"/>
                        <field name="date"/>
                        <field name="material_type"/>
                    </group>
                        <group string="Logistics">
                            <field name="warehouse_id"/>
                            <field name="vendor_id"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    <group string="Totals">
                        <field name="totqtytoorder"/>
                        <field name="totmaxqtyneeded"/>
                        <field name="tot_total_height"/>
                    </group>
                    <field name="line_ids" >
                        <list editable="bottom">
                            <field name="product_tmpl_id"/>
                            <field name="warehouse_code"/>
                            <field name="product_profile"/>
                            <field name="color"/>
                            <field name="profile_length" readonly="1"/>
                            <field name="total_length"/>
                            <field name="width"/>
                            <field name="available_qty"/>
                            <field name="max_qty_needed"/>
                            <field name="min_qty_needed"/>
                            <field name="increase_percent"/>
                            <field name="qtytoorder"/>
                        </list>
                    </field>
                </sheet>

                    <!-- 2. PLACE THE CHATTER PANEL HERE (Outside <sheet>, inside <form>) -->
                    <chatter>
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </chatter>                
            </form>
        </field>
    </record>
    <record id="action_cutlist_sum" model="ir.actions.act_window">
        <field name="name">Cut List Summaries</field>
        <field name="res_model">cutlist_sum</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_cutlist_sum_form" model="ir.actions.act_window">
        <field name="name">Cut List Summaries Form</field>
        <field name="context">{'default_ajo_order_id': active_id}</field>
        <field name="res_model">cutlist_sum</field>
        <field name="view_mode">form</field>
    </record>
    <menuitem
        id="menu_cutlist_sum"
        name="Cut List Summary"
        parent="menu_ajo"
        action="action_cutlist_sum"
        sequence="13"/>
</odoo>
