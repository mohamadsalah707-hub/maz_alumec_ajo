<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mrp_bom_form_inherit_dimensions" model="ir.ui.view">
        <field name="name">mrp.bom.form.inherit.dimensions</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='bom_line_ids']//field[@name='product_qty'][1]" position="before">
                <field name="width"/>
                <field name="height"/>
            </xpath>
        </field>
    </record>

    <record id="view_mrp_production_form_inherit_dimensions" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.dimensions</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_raw_ids']//field[@name='forecast_availability']" position="before">
                <field name="width"/>
                <field name="height"/>
                <field name="remaining_length" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_lot_form_inherit_offcut" model="ir.ui.view">
        <field name="name">stock.lot.form.inherit.offcut</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="offcut_length"/>
            </xpath>
        </field>
    </record>
</odoo>
