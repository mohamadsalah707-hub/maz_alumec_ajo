<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="purchase_order_line_checklist_list_view" model="ir.ui.view">
        <field name="name">purchase.order.line.checklist.list</field>
        <field name="model">purchase.order.line.checklist</field>
        <field name="arch" type="xml">
            <list string="ISO Checklists">
                <field name="purchase_order_id" class="w-10"/>
                <field name="partner_id" class="w-10"/>
                <field name="score_total"/>
                <field name="max_score"/>
                <field name="score_percentage"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'completed'" class="w-10"/>
                <field name="comments" class="w-70"/>
            </list>
        </field>
    </record>

    <record id="purchase_order_line_checklist_form_view" model="ir.ui.view">
        <field name="name">purchase.order.line.checklist.form</field>
        <field name="model">purchase.order.line.checklist</field>
        <field name="arch" type="xml">
            <form string="ISO Checklist">
                <header>
                    <button name="action_complete_checklist" type="object" string="Mark as Completed" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <span>ISO Checklist for Purchase Order</span>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="purchase_order_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="max_score" readonly="1"/>
                            <field name="score_total" readonly="1"/>
                            <field name="score_percentage" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Quality Checks"/>
                    <group>
                        <group>
                            <field name="fax_check"/>
                            <field name="fax_check_comments" placeholder="Add comments..."/>
                        </group>
                        <group>
                            <field name="ral_color_check"/>
                            <field name="ral_color_check_comments" placeholder="Add comments..."/>
                        </group>
                        <group>
                            <field name="quantity_verified"/>
                            <field name="quantity_verified_comments" placeholder="Add comments..."/>
                        </group>
                        <group>
                            <field name="price_approved"/>
                            <field name="price_approved_comments" placeholder="Add comments..."/>
                        </group>
                        <group>
                            <field name="glass_type_check"/>
                            <field name="glass_type_check_comments" placeholder="Add comments..."/>
                        </group>
                        <group>
                            <field name="polished_glass_edge"/>
                            <field name="polished_glass_edge_comments" placeholder="Add comments..."/>
                        </group>
                        <group>
                            <field name="structural_sealant"/>
                            <field name="structural_sealant_comments" placeholder="Add comments..."/>
                        </group>
                        <group>
                            <field name="dimensions_checked"/>
                            <field name="dimensions_checked_comments" placeholder="Add comments..."/>
                        </group>
                        <group>
                            <field name="stock_quantity_checked"/>
                            <field name="stock_quantity_checked_comments" placeholder="Add comments..."/>
                        </group>
                        <group>
                            <field name="project_manager_approval"/>
                            <field name="project_manager_approval_comments" placeholder="Add comments..."/>
                        </group>
                        <group>
                            <field name="general_manager_approval"/>
                            <field name="general_manager_approval_comments" placeholder="Add comments..."/>
                        </group>
                    </group>
                    <separator string="General comments"/>
                    <group>
                        <field name="comments" placeholder="Add general comments..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="purchase_order_line_checklist_search_view" model="ir.ui.view">
        <field name="name">purchase.order.line.checklist.search</field>
        <field name="model">purchase.order.line.checklist</field>
        <field name="arch" type="xml">
            <search>
                <field name="purchase_order_id"/>
                <field name="partner_id"/>
                <field name="state"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="completed" string="Completed" domain="[('state','=','completed')]"/>
            </search>
        </field>
    </record>

    <record id="action_purchase_order_line_checklist" model="ir.actions.act_window">
        <field name="name">ISO Checklists</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">purchase.order.line.checklist</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('purchase_order_line_checklist_list_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('purchase_order_line_checklist_form_view')})
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No ISO Checklists found. Create one from a purchase order.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_purchase_order_line_checklist"
        name="ISO Checklists"
        parent="purchase.menu_purchase_form_action"
        action="action_purchase_order_line_checklist"
        sequence="10"/>
</odoo>
