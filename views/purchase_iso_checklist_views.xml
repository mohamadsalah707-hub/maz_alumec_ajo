<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="purchase_order_line_checklist_list_view" model="ir.ui.view">
        <field name="name">purchase.order.line.checklist.list</field>
        <field name="model">purchase.order.line.checklist</field>
        <field name="arch" type="xml">
            <list string="ISO Checklists">
                <field name="purchase_order_id"/>
                <field name="purchase_line_id"/>
                <field name="score_total"/>
                <field name="max_score"/>
                <field name="score_percentage"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'completed'"/>
            </list>
        </field>
    </record>

    <record id="purchase_order_line_checklist_form_view" model="ir.ui.view">
        <field name="name">purchase.order.line.checklist.form</field>
        <field name="model">purchase.order.line.checklist</field>
        <field name="arch" type="xml">
            <form string="ISO Checklist">
                <header>
                    <button name="action_complete_checklist" type="object" string="Mark as Completed" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <span>ISO Checklist for Purchase Order Line</span>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="purchase_order_id" readonly="1"/>
                            <field name="purchase_line_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="max_score" readonly="1"/>
                            <field name="score_total" readonly="1"/>
                            <field name="score_percentage" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Quality Checks"/>
                    <group>
                        <field name="quality_check"/>
                        <field name="quantity_check"/>
                        <field name="packaging_check"/>
                        <field name="documentation_check"/>
                        <field name="expiry_date_check"/>
                        <field name="price_verification"/>
                    </group>
                    <separator string="Notes"/>
                    <group>
                        <field name="notes" nolabel="1" placeholder="Add custom notes here..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="purchase_order_line_checklist_search_view" model="ir.ui.view">
        <field name="name">purchase.order.line.checklist.search</field>
        <field name="model">purchase.order.line.checklist</field>
        <field name="arch" type="xml">
            <search>
                <field name="purchase_order_id"/>
                <field name="purchase_line_id"/>
                <field name="state"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="completed" string="Completed" domain="[('state','=','completed')]"/>
            </search>
        </field>
    </record>

    <record id="action_purchase_order_line_checklist" model="ir.actions.act_window">
        <field name="name">ISO Checklists</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">purchase.order.line.checklist</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('purchase_order_line_checklist_list_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('purchase_order_line_checklist_form_view')})
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No ISO Checklists found. Create one from a purchase order line.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_purchase_order_line_checklist"
        name="ISO Checklists"
        parent="purchase.menu_purchase_form_action"
        action="action_purchase_order_line_checklist"
        sequence="10"/>
</odoo>
