<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<!--    Sale order form view inherited for adding warehouse field-->
	<record id="purchase_order_form_inherit" model="ir.ui.view">
		<field name="name">purchase.order.form.inherit</field>
		<field name="model">purchase.order</field>
		<field name="inherit_id" ref="purchase.purchase_order_form"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='order_line']/list/field[@name='product_qty']" position="before">
				<field name="product_code" optional="show"/>
				<field name="categ_id" optional="show"/>
				<field name="sub_categ_id" optional="show"/>
				<field name="width"/>
				<field name="total_length" string="Height"/>
				<field name="area" string="Area/m²"/>
				<field name="color"/>
				<field name="glass_type_id" optional="show"/>
				<field name="profile_length" optional="show"/>
				<field name="alu_weight_per_meter" optional="show"/>
				<field name="alu_price_per_kg" optional="show"/>
			</xpath>
			<xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="after">
				<field name="alu_unit_cost" string="Unit Cost" optional="show"/>
				<field name="price_unit_discounted" string="Net Cost" optional="show"/>
				<field name="vat_applicable" optional="show"/>
			</xpath>
			<xpath expr="//page[@name='purchase_delivery_invoice']/group" position="after">
				<group>
					<group name="maz_shipping_info" string="Shipping">
						<field name="shipping_method"/>
						<field name="shipping_terms"/>
						<field name="global_discount_percent"/>
						<field name="global_discount_amount"/>
					</group>
					<group name="maz_approval_info" string="Approval">
						<field name="approved_by_id"/>
						<field name="nb_pages"/>
						<field name="memo_1"/>
						<field name="memo_2"/>
						<field name="memo_3"/>
					</group>
				</group>
			</xpath>
			<xpath expr="//sheet/notebook" position="inside">
				<page string="Extra Costs" name="maz_extra_costs">
					<field name="extra_cost_line_ids">
						<list editable="bottom">
							<field name="glass_type_id"/>
							<field name="description"/>
							<field name="cost"/>
						</list>
					</field>
				</page>
			</xpath>
		</field>
	</record>
    <record id="purchase_order_list_inherit_iso_checklist" model="ir.ui.view">
        <field name="name">purchase.order.list.inherit.iso.checklist</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='state']" position="after">
                <button name="action_open_iso_checklist" type="object" string="ISO Checklist" icon="fa-list-check" class="oe_highlight"/>
            </xpath>
        </field>
    </record>
</odoo>