<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_label_layout_form" model="ir.ui.view">
        <field name="name">product.label.layout.form</field>
        <field name="model">maz_alumec_ajo.product_label_layout</field>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="product_ids" invisible="1"/>
                        <field name="ajo_line_ids" invisible="1"/>
                        <field name="ajo_quantity"/>
                        <field name="quantity" invisible="ajo_quantity == 'ajo'"/>
                        <field name="print" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button name="process" string="Print" type="object" class="btn-primary"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
